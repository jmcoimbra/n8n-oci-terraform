# Copie este arquivo para terraform.tfvars e preencha.
# terraform.tfvars está no .gitignore. NUNCA commite.

# ===== OCI auth =====
tenancy_ocid     = "ocid1.tenancy.oc1..EXEMPLO"
user_ocid        = "ocid1.user.oc1..EXEMPLO"
fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
private_key_path = "~/.oci/oci_api_key.pem"
region           = "sa-saopaulo-1"

# ===== Projeto =====
project_name = "n8n"

# IMPORTANTE: crie um compartment dedicado no console OCI (Identity > Compartments > Create).
# NÃO use o root/tenancy. A dynamic group terá acesso a TODOS os recursos do compartment.
compartment_ocid = "ocid1.compartment.oc1..EXEMPLO"

# ===== Rede =====
# OBRIGATÓRIO restringir SSH ao seu IP: rode 'curl ifconfig.me' e cole com /32.
allowed_ssh_cidr = "177.123.45.67/32"

# ===== Compute =====
# Defaults cabem no Always Free. Não altere se não souber o que está fazendo.
# instance_shape      = "VM.Standard.A1.Flex"
# instance_ocpus      = 1
# instance_memory_gb  = 6
# boot_volume_size_gb = 50

# Cole o conteúdo completo de ~/.ssh/id_ed25519.pub (ou id_rsa.pub)
ssh_public_key = "ssh-ed25519 AAAA... seu-email@exemplo.com"

# ===== Domínio =====
domain     = "n8n.meusite.com.br"
acme_email = "voce@exemplo.com"

# ===== n8n =====
n8n_basic_auth_user = "admin"

# ===== Imagens Docker (pinned por segurança) =====
# Atualize deliberadamente após testar compatibilidade.
# n8n_image      = "n8nio/n8n:1.77.0"
# postgres_image = "postgres:16.4-alpine"
# caddy_image    = "caddy:2.8.4-alpine"

# ===== Backup offsite (Object Storage Always Free: 20 GB) =====
# enable_offsite_backup = true
